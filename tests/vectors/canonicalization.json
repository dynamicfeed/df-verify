{
  "standard": "DF-VERIFY/1",
  "canonicalization": "json-sorted-compact",
  "note": "canonical = UTF-8 bytes of this string. Equivalent to Python json.dumps(payload_without_signature, sort_keys=True, separators=(',',':')).",
  "vectors": [
    {
      "name": "empty object",
      "payload": {},
      "canonical": "{}"
    },
    {
